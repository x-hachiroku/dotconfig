[Unit]
ConditionPathIsMountPoint=/mnt/data


[Service]
Restart=always
RestartSec=60


[Install]
WantedBy=default.target


[Container]
ContainerName=kavita
Image=docker.io/jvmilazz0/kavita

PublishPort=8700:5000

Volume=%h/containers/kavita:/kavita/config
Volume=/mnt/data/shared/manga:/manga:ro
Volume=/etc/localtime:/etc/localtime:ro
