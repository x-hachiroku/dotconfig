[Unit]
Requires=podman.socket
After=podman.socket


[Service]
Restart=always
RestartSec=60


[Install]
WantedBy=default.target


[Container]
ContainerName=podman-exporter
Image=quay.io/navidys/prometheus-podman-exporter

User=1000:1000
UserNS=keep-id

Network=prometheus.network

Volume=%h/containers/podman-exporter:/.config
Volume=${XDG_RUNTIME_DIR}/podman/podman.sock:/run/podman/podman.sock
Volume=/etc/localtime:/etc/localtime:ro

Environment=CONTAINER_HOST=unix:///run/podman/podman.sock
