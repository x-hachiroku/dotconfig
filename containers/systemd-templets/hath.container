[Unit]
ConditionPathIsMountPoint=/mnt/solar
ConditionPathIsMountPoint=/mnt/data


[Service]
Restart=always
RestartSec=60


[Install]
WantedBy=default.target


[Container]
ContainerName=hath
Image=localhost/hath

Pod=hath.pod

Ulimit=nofile=65536:65536

Volume=%h/containers/hath:/hath
Volume=/mnt/solar/repo/hath_cache:/cache
Volume=/mnt/data/repo/hath:/downloads
Volume=/etc/localtime:/etc/localtime:ro
