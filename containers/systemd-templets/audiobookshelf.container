[Unit]
ConditionPathIsMountPoint=/mnt/data


[Service]
Restart=always
RestartSec=60


[Install]
WantedBy=default.target


[Container]
ContainerName=audiobookshelf
Image=ghcr.io/advplyr/audiobookshelf

PublishPort=8900:80

Volume=%h/containers/audiobookshelf/config:/config
Volume=%h/containers/audiobookshelf/metadata:/metadata
Volume=/mnt/data/shared/audiobooks:/audiobooks:ro
Volume=/etc/localtime:/etc/localtime:ro
