[Unit]
ConditionPathIsMountPoint=/mnt/data


[Service]
Restart=always
RestartSec=60


[Install]
WantedBy=default.target


[Container]
ContainerName=tgsync
Image=localhost/tgsync

Network=postgres.network

Volume=%h/containers/tgsync/appdata:/appdata
Volume=%h/containers/tgsync/incomplete:/incomplete
Volume=/mnt/data/repo/tg:/media
Volume=/etc/localtime:/etc/localtime:ro
